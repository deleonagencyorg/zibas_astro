---
//src/components/blog/NewsCarousel.astro
import '@fortawesome/fontawesome-free/css/all.min.css';

interface Item {
  id: string;
  slug: string;
  title: string;
  preview?: string;
  image?: string;
  summary?: string;
  published_date?: string;
  category?: string;
}

interface Props {
  id?: string;
  items: Item[];
  currentLang?: string;
}

const { id = 'news-carousel', items = [], currentLang = 'es' } = Astro.props as Props;

const noContent = currentLang === 'es' ? 'No hay contenido disponible' : 'No content available';
---

<div id={id} data-news-carousel data-lang={currentLang} class="w-full">
  {items.length === 0 ? (
    <div class="w-full py-10 flex items-center justify-center">
      <p class="text-white text-center text-lg md:text-xl font-semibold">{noContent}</p>
    </div>
  ) : (
    <div class="relative w-full">
      <!-- Track -->
      <div class="overflow-hidden w-full">
        <div class="flex transition-transform duration-500 ease-out will-change-transform" data-track></div>
      </div>

      <!-- Flechas DESKTOP (sobre los bordes del carousel) -->
      <button data-prev aria-label="Prev"
        class="news-arrow hidden md:inline-flex absolute left-2 lg:left-4 top-1/2 -translate-y-1/2 z-20">
        <i class="fa-solid fa-arrow-left"></i>
      </button>
      <button data-next aria-label="Next"
        class="news-arrow hidden md:inline-flex absolute right-2 lg:right-4 top-1/2 -translate-y-1/2 z-20">
        <i class="fa-solid fa-arrow-right"></i>
      </button>

      <div class="mt-4 hidden items-center justify-center" data-empty>
        <span class="text-white text-lg md:text-xl font-semibold">{noContent}</span>
      </div>

      <!-- Provide initial items as JSON for reliable init -->
      <script type="application/json" data-items>{JSON.stringify(items)}</script>
    </div>
  )}
</div>

<style is:global>
  .news-arrow {
    align-items: center;
    justify-content: center;
    width: clamp(2.5rem, 4vw, 3.5rem);
    height: clamp(2.5rem, 4vw, 3.5rem);
    border-radius: 9999px;
    border: 2px solid #ffffff;
    background-color: #FD6600;
    color: #ffffff;
    font-size: clamp(1rem, 1.6vw, 1.4rem);
    transition: background-color .25s ease, transform .2s ease;
    cursor: pointer;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.25);
    line-height: 1;
  }
  .news-arrow:hover {
    background-color: #e25c00;
  }
  @media (max-width: 767px) {
    .news-arrow {
      width: 2.25rem;
      height: 2.25rem;
      font-size: 0.9rem;
    }
  }
</style>
<script>
  // @ts-check
  /** @typedef {{id:string, slug:string, title:string, preview?:string, image?:string, summary?:string, published_date?:string, category?:string}} Item */

  /**
   * @param {string} text
   * @param {number} max
   */
  function truncate(text, max) {
    const t = (text || '').trim();
    if (t.length <= max) return t;
    return t.slice(0, max).replace(/\s+\S*$/, '') + '…';
  }

  /**
   * Relative "published" label based on a date string.
   * @param {string|undefined} dateStr
   * @param {string} lang
   */
  function publishedLabel(dateStr, lang) {
    const es = lang === 'es';
    const prefix = es ? 'Publicado hace:' : 'Published:';
    if (!dateStr) return '';
    let ts = 0;
    if (/^\d{1,2}\/\d{1,2}\/\d{4}$/.test(dateStr)) {
      const [d, m, y] = dateStr.split('/').map(Number);
      ts = new Date(y, (m || 1) - 1, d || 1).getTime();
    } else {
      const p = Date.parse(dateStr);
      ts = isNaN(p) ? 0 : p;
    }
    if (!ts) return `${prefix} ${dateStr}`;
    const diff = Math.max(0, Date.now() - ts);
    const mins = Math.floor(diff / 60000);
    const hours = Math.floor(diff / 3600000);
    const days = Math.floor(diff / 86400000);
    let value;
    if (mins < 60) value = es ? `${mins} min` : `${mins} min`;
    else if (hours < 24) value = es ? `${hours} h` : `${hours} h`;
    else if (days < 30) value = es ? `${days} día${days === 1 ? '' : 's'}` : `${days} day${days === 1 ? '' : 's'}`;
    else value = dateStr;
    return `${prefix} ${value}`;
  }

  /**
   * @param {HTMLElement} root
   * @param {Item[]} items
   * @param {string} currentLang
   */
  const initNewsCarousel = (root, items, currentLang) => {
    if (!root) return;
    const track = /** @type {HTMLElement|null} */(root.querySelector('[data-track]'));
    const empty = /** @type {HTMLElement|null} */(root.querySelector('[data-empty]'));
    const itemsScript = /** @type {HTMLScriptElement|null} */(root.querySelector('script[data-items]'));

    /** @type {Item[]} */
    let data = Array.isArray(items) ? items : [];
    let index = 0;
    /** @type {number|undefined} */
    let autoplayInterval;
    const langAttr = root.getAttribute('data-lang') || '';
    const lang = (currentLang && typeof currentLang === 'string' && currentLang) || langAttr || (location.pathname.split('/')[1] || 'es');
    const readMore = lang === 'es' ? 'Leer más' : 'Read more';
    const fallbackImg = 'https://snack.yummiespromociones.com/SnacksyummiesAssets/final_creators.webp';

    if (!data.length && itemsScript && itemsScript.textContent) {
      try { data = JSON.parse(itemsScript.textContent); } catch {}
    }

    function buildSlides() {
      if (!track) return;
      track.innerHTML = '';

      if (!data.length) {
        track.style.transform = 'translateX(0)';
        index = 0;
        if (empty) { empty.classList.remove('hidden'); empty.classList.add('flex'); }
        return;
      }
      if (empty) { empty.classList.add('hidden'); empty.classList.remove('flex'); }

      data.forEach((item) => {
        const slide = document.createElement('div');
        slide.className = 'w-full flex-shrink-0';
        const href = `/${lang}/blog/${item.slug || item.id}`;
        const img = item.preview || item.image || fallbackImg;
        const body = truncate(item.summary || '', 220);
        const published = publishedLabel(item.published_date, lang);

        slide.innerHTML = `
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-10 items-center px-2 md:px-12 lg:px-16">
            <!-- Imagen -->
            <div class="relative w-full">
              <a href="${href}" class="block group relative w-full overflow-hidden rounded-[1.5rem]" style="aspect-ratio: 16/11;">
                <img src="${img}" alt="${item.title}" onerror="this.onerror=null;this.src='${fallbackImg}'"
                  class="absolute inset-0 w-full h-full object-cover transform transition-transform duration-500 ease-out group-hover:scale-105" loading="lazy" />
              </a>
              <!-- Flechas MOBILE sobre la imagen -->
              <button data-prev aria-label="Prev" class="news-arrow is-mobile inline-flex md:hidden absolute left-1 top-1/2 -translate-y-1/2 z-20">
                <i class="fa-solid fa-arrow-left"></i>
              </button>
              <button data-next aria-label="Next" class="news-arrow is-mobile inline-flex md:hidden absolute right-1 top-1/2 -translate-y-1/2 z-20">
                <i class="fa-solid fa-arrow-right"></i>
              </button>
            </div>

            <!-- Texto -->
            <div class="text-white">
              <a href="${href}" class="block hover:opacity-90 transition-opacity">
                <h3 class="font-title font-bold italic uppercase leading-tight mb-4"
                  style="font-size: clamp(1.5rem, 3.2vw, 3rem);">${item.title}</h3>
              </a>
              ${body ? `<p class="italic leading-relaxed mb-6" style="font-size: clamp(0.9rem, 1.2vw, 1.05rem);">${body}</p>` : ''}
              ${published ? `<p class="font-bold" style="font-size: clamp(0.9rem, 1.2vw, 1.05rem);">${published}</p>` : ''}
            </div>
          </div>
        `;
        track.appendChild(slide);
      });

      track.style.width = data.length * 100 + '%';
      track.querySelectorAll(':scope > div').forEach((slide) => {
        (/** @type {HTMLElement} */(slide)).style.width = (100 / data.length) + '%';
      });
      index = Math.min(index, Math.max(0, data.length - 1));
      update();
    }

    function update() {
      if (!track) return;
      const slidesCount = track.children.length;
      if (slidesCount === 0) return;
      track.style.transform = `translateX(-${index * (100 / slidesCount)}%)`;
    }

    function go(delta) {
      const slidesCount = track ? track.children.length : 0;
      if (slidesCount === 0) return;
      index = (index + delta + slidesCount) % slidesCount;
      update();
    }

    function startAutoplay() {
      stopAutoplay();
      autoplayInterval = window.setInterval(() => go(1), 6000);
    }
    function stopAutoplay() {
      if (autoplayInterval !== undefined) {
        clearInterval(autoplayInterval);
        autoplayInterval = undefined;
      }
    }

    // Delegación de eventos para flechas (desktop estáticas + mobile dentro de slides)
    root.addEventListener('click', (e) => {
      const target = /** @type {HTMLElement} */(e.target);
      const prevBtn = target.closest('[data-prev]');
      const nextBtn = target.closest('[data-next]');
      if (!prevBtn && !nextBtn) return;
      e.preventDefault();
      stopAutoplay();
      go(prevBtn ? -1 : 1);
      startAutoplay();
    });

    root.addEventListener('mouseenter', stopAutoplay);
    root.addEventListener('mouseleave', startAutoplay);

    /** @param {Item[]} newItems */
    function setData(newItems) {
      data = Array.isArray(newItems) ? newItems : [];
      index = 0;
      buildSlides();
      startAutoplay();
    }

    const rootId = root.getAttribute('id') || 'news-carousel';
    (/** @type {any} */(window))._newsCarousels = (/** @type {any} */(window))._newsCarousels || {};
    (/** @type {any} */(window))._newsCarousels[rootId] = { setData };

    buildSlides();
    startAutoplay();
  };

  function autoInit() {
    document.querySelectorAll('[data-news-carousel]').forEach((rootEl) => {
      const root = /** @type {any} */(rootEl);
      if (root._carouselInitialized) return;
      root._carouselInitialized = true;

      let items = [];
      const dataScript = /** @type {HTMLScriptElement|null} */(root.querySelector('script[data-items]'));
      if (dataScript && dataScript.textContent) {
        try {
          items = JSON.parse(dataScript.textContent);
        } catch (e) {
          console.error(`[NewsCarousel] Failed to parse embedded JSON for ${root.id}:`, e);
        }
      }
      const lang = root.getAttribute('data-lang') || '';
      initNewsCarousel(root, items, lang);
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', autoInit);
  } else {
    autoInit();
  }
  document.addEventListener('astro:page-load', autoInit);
  document.addEventListener('astro:after-swap', autoInit);
</script>
