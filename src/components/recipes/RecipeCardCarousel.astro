---
import LazyImage from '../common/LazyImage.astro';
import { getLocale } from '../../i18n/i18n';
import { Image } from 'astro:assets';
import { fade } from 'astro:transitions';

interface Props {
  image: string;
  title: string;
  time?: string;
  id: string;
  textColor?: string;
  iconColor?: string;
  hoverImage?: string;
  difficulty?: string;
  servings?: number;
  rating?: number;
  isMainCard?: boolean;
  video?: string;
}

const { 
  image, 
  title, 
  time = "---", 
  id,
  textColor = 'text-blue-900',
  iconColor = 'text-blue-900',
  hoverImage = image,
  difficulty = "---",
  servings = 0,
  rating = 0,
  isMainCard = false,
  video
} = Astro.props;

const currentLocale = getLocale();
const recipeLink = `/${currentLocale}/${currentLocale === 'es' ? 'recetas' : 'recipes'}/${id}`;
const viewRecipeText = currentLocale === 'es' ? 'Ver Receta' : 'View Recipe';
---

<div 
  class={`block group relative transition-all duration-500 ease-in-out w-full ${
    isMainCard ? 'md:w-[430px] md:h-[520px] lg:h-[562px]' : 'md:w-[280px] md:h-[520px] lg:h-[562px]'
  }`}
  transition:animate="fade"
>
  <!-- Container principal con las medidas específicas -->
  <div class={`flex flex-col ${isMainCard ? 'w-[530px] h-[520px] md:h-[562px]' : 'w-[310px] h-[520px] md:h-[562px]' } relative overflow-visible
  mx-4 mb-6
  md:mx-6 md:mb-8
  lg:mx-8 lg:mb-10`}>
    <!-- Overlay gris para tarjetas no principales: oculto en mobile para tener estado activo por defecto -->
    {!isMainCard && (
      <div class="absolute inset-0 bg-[#0A0A0A40] z-10 rounded-[30px] hidden md:block"></div>
    )}
    
    <!-- Imagen - clickable para video si existe -->
    <div class={`relative overflow-hidden flex-shrink-0 w-full aspect-[430/340] md:aspect-auto ${
      isMainCard 
        ? 'md:w-[430px] md:h-[280px] lg:h-[320px] rounded-t-[30px] border-t border-r border-l border-[#388BFF]' 
        : 'md:w-[280px] md:h-[300px] lg:h-[320px] rounded-t-[30px] border-t border-r border-l border-black border-opacity-50'
    }`}>
      {video ? (
        <button 
          type="button"
          class="absolute inset-0 w-full h-full p-0 border-0 bg-transparent cursor-pointer z-20"
          onclick={`window.openYouTubeModal && window.openYouTubeModal('${video}')`}
          aria-label={`Ver video de ${title}`}
        >
          <LazyImage
            src={image}
            alt={title}
            class="w-full h-full object-cover pointer-events-none"
            transition:name={`recipe-image-${id}`}
          />
          <!-- Icono de play centrado -->
          <div class="absolute inset-0 flex items-center justify-center bg-black/30 group-hover:bg-black/40 transition-colors">
            <div class="w-14 h-14 md:w-16 md:h-16 rounded-full bg-white/80 flex items-center justify-center group-hover:scale-110 transition-transform duration-300 shadow-lg">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 md:h-8 md:w-8 text-[#F04F00] ml-1" viewBox="0 0 20 20" fill="currentColor">
                <path d="M6.3 5.84a.5.5 0 0 1 .77-.42l7.15 4.16a.5.5 0 0 1 0 .84l-7.15 4.16a.5.5 0 0 1-.77-.42V5.84z" />
              </svg>
            </div>
          </div>
        </button>
      ) : (
        <div class="absolute inset-0 w-full h-full">
          <LazyImage
            src={image}
            alt={title}
            class="w-full h-full object-cover"
            transition:name={`recipe-image-${id}`}
          />
        </div>
      )}
    </div>
    
    <!-- Información -->
    <a 
      href={recipeLink}
      class={`flex-shrink-0 md:${isMainCard ? 'w-[430px]' : 'w-[280px]'}
        ${isMainCard 
          ? 'min-h-[180px] md:min-h-[320px] bg-[#F8E31F] rounded-b-[30px] border-r border-b border-l border-black border-opacity-50' 
          : 'w-[310px] h-[262px] bg-[#F8E31F] rounded-b-[30px] border border-black border-opacity-50'
        } p-6 flex flex-col justify-between gap-3 md:gap-6 hover:bg-[#F5E01A] transition-colors`}
    >
      <!-- Título -->
      <h3 class="font-title font-bold text-black leading-tight flex-1 flex items-center text-2xl">{title}</h3>
      
      <!-- Botón Ver Receta -->
      <div class="flex justify-center">
        <div class="flex py-5 px-2.5 justify-center w-full items-center gap-2.5 rounded-[15px] border border-[#388BFF66] bg-[#FFED41] text-black text-xl font-bold hover:bg-yellow-300 transition-colors">
          {viewRecipeText}
        </div>
      </div>
    </a>
  </div>
</div>
