---
// src/components/common/YouTubeVideoModal.astro
interface Props {
  modalId?: string;
}

const { modalId = 'youtube-video-modal' } = Astro.props;
---

<!-- Modal de Video de YouTube -->
<div id={modalId} class="fixed inset-0 z-[9999] hidden" aria-hidden="true">
  <div class="absolute inset-0 bg-black/80 backdrop-blur-sm hidden md:block" data-video-backdrop></div>

  <div class="absolute inset-0 flex items-center justify-center p-0 md:p-6 bg-black md:bg-transparent">
    <div class="w-full h-full md:h-auto md:max-w-5xl bg-black md:rounded-lg overflow-hidden relative shadow-2xl">
      <button type="button" id="close-btn"
        class="absolute top-4 right-4 z-[100000] w-11 h-11 rounded-full bg-black/70 hover:bg-black/90 text-white flex items-center justify-center transition-all"
        aria-label="Cerrar video">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>

      <div class="relative w-full h-full md:aspect-video bg-black">
        <!-- YouTube -->
        <iframe id="blog-modal-iframe" class="w-full h-full" src="" frameborder="0"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; fullscreen"
          allowfullscreen></iframe>
        <!-- Video directo -->
        <video id="blog-modal-video" class="w-full h-full hidden" controls autoplay playsinline></video>
        <!-- Imagen -->
        <img id="blog-modal-image" class="w-full h-full object-contain hidden" src="" alt="" />
      </div>
    </div>
  </div>
</div>

<script is:inline>
  (function () {
    function initModal() {
      const modal = document.getElementById('youtube-video-modal');
      if (!modal) return;

      const iframe = document.getElementById('blog-modal-iframe');
      const video = document.getElementById('blog-modal-video');
      const closeBtn = document.getElementById('close-btn');
      const backdrop = modal.querySelector('[data-video-backdrop]');

      window.closeYouTubeModal = function () {
        modal.classList.add('hidden');
        modal.classList.remove('flex');
        document.body.style.overflow = '';
        const navbar = document.querySelector('header') || document.querySelector('nav');
        if (navbar) navbar.style.zIndex = '';
      };

      window.openYouTubeModal = function (videoUrl) {
  if (!videoUrl || !modal) return;

  const isYoutube = videoUrl.includes('youtube.com') || videoUrl.includes('youtu.be');
  const isImage = /\.(jpg|jpeg|png|webp|gif|avif)(\?.*)?$/i.test(videoUrl);
  const imgEl = document.getElementById('blog-modal-image');

  if (isImage && imgEl) {
    imgEl.src = videoUrl;
    imgEl.classList.remove('hidden');
    iframe.classList.add('hidden');
    video.classList.add('hidden');
  } else if (isYoutube) {
    let videoId = null;
    const patterns = [
      /youtube\.com\/watch\?v=([a-zA-Z0-9_-]{11})/,
      /youtu\.be\/([a-zA-Z0-9_-]{11})/,
      /youtube\.com\/embed\/([a-zA-Z0-9_-]{11})/,
      /youtube\.com\/shorts\/([a-zA-Z0-9_-]{11})/,
    ];
    for (const pattern of patterns) {
      const match = videoUrl.match(pattern);
      if (match) { videoId = match[1]; break; }
    }
    if (videoId) {
      iframe.src = `https://www.youtube.com/embed/${videoId}?autoplay=1&rel=0`;
      iframe.classList.remove('hidden');
      video.classList.add('hidden');
      if (imgEl) imgEl.classList.add('hidden');
    }
  } else {
    video.src = videoUrl;
    video.classList.remove('hidden');
    iframe.classList.add('hidden');
    if (imgEl) imgEl.classList.add('hidden');
  }

  modal.classList.remove('hidden');
  modal.classList.add('flex');
  document.body.style.overflow = 'hidden';
  const navbar = document.querySelector('header') || document.querySelector('nav');
  if (navbar) navbar.style.zIndex = '0';
};

      if (closeBtn) closeBtn.addEventListener('click', window.closeYouTubeModal);
      if (backdrop) backdrop.addEventListener('click', window.closeYouTubeModal);
      document.addEventListener('keydown', (e) => { if (e.key === 'Escape') window.closeYouTubeModal(); });
    }

    document.readyState === 'loading'
      ? document.addEventListener('DOMContentLoaded', initModal)
      : initModal();

    document.addEventListener('astro:page-load', initModal);
  })();
</script>