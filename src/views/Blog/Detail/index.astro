<script>
  function initMediaCarousel() {
    const root = document.querySelector('[data-media-carousel]');
    if (!root) return;
    const track = root.querySelector('[data-media-track]');
    if (!track || track.children.length <= 1) return;
    const prev = root.querySelector('[data-media-prev]');
    const next = root.querySelector('[data-media-next]');
    let index = 0;
    function update() {
      track.style.transform = 'translateX(-' + (index * 100) + '%)';
      if (prev) prev.style.opacity = index === 0 ? '0.4' : '1';
      if (next) next.style.opacity = index >= track.children.length - 1 ? '0.4' : '1';
    }
    if (prev) prev.addEventListener('click', function() { index = Math.max(0, index - 1); update(); });
    if (next) next.addEventListener('click', function() { index = Math.min(track.children.length - 1, index + 1); update(); });
    update();
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initMediaCarousel);
  } else {
    initMediaCarousel();
  }
  document.addEventListener('astro:page-load', initMediaCarousel);
  document.addEventListener('astro:after-swap', initMediaCarousel);
</script>


