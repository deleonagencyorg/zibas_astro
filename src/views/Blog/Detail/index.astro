---
import '@fortawesome/fontawesome-free/css/all.min.css';
import { type Locale } from '../../../i18n/i18n';
import Breadcrumb from '../../../components/common/Breadcrumb/Breadcrumb.astro';
import BlogCard from '../../../components/blog/BlogCard.astro';
import BlogDetailSkeleton from '../../../components/blog/BlogDetailSkeleton.astro';
import MediaCarousel from '../../../components/blog/MediaCarousel.astro';
import { fade } from 'astro:transitions';
import ShareModal from '../../../components/common/ShareModal.astro';
import ShareButton from '../../../components/common/ShareButton.astro';
import VideoModal from '../../../components/common/YouTubeVideoModal.astro';

interface Props {
  blogPost: {
    id: string;
    slug: string;
    title: string;
    content: string;
    image: string;
    videos?: string[]; 
    author: string;
    published_date: string;
  };
  currentLang: Locale;
  allBlogPosts?: Array<{
    id: string;
    slug: string;
    title: string;
    summary: string;
    preview?: string;
    image: string;
    published_date: string;
  }>;
  isLoading?: boolean;
}

const { blogPost, currentLang, allBlogPosts = [], isLoading = false } = Astro.props;

// Filter out the current blog post and get up to 4 suggested posts
const suggestedPosts = allBlogPosts
  .filter(post => post.id !== blogPost.id)
  .slice(0, 4);

const readMoreTitle = currentLang === 'es' ? 'Otras Noticias' : 'Other News';

// Función para extraer el id de youtube de una URL
const getYoutubeId = (url: string) => {
  const regExp = /^.*(youtu.be\/|v\/|u\/\w\/|embed\/|watch\?v=|\&v=)([^#\&\?]*).*/;
  const match = url.match(regExp);
  return (match && match[2].length === 11) ? match[2] : null;
};

const videos = blogPost.videos || [];

// Build media items array (main image + videos)
interface MediaItem { type: 'image' | 'video'; src?: string; url?: string; youtubeId: string | null; thumb: string; }
const mediaItems: MediaItem[] = [];

if (blogPost.image) {
  mediaItems.push({ 
    type: 'image', 
    src: blogPost.image, 
    url: undefined, 
    youtubeId: null, 
    thumb: blogPost.image 
  });
}

for (const v of videos) {
  const ytId = getYoutubeId(v.trim());
  const thumb = ytId 
    ? `https://img.youtube.com/vi/${ytId}/mqdefault.jpg` 
    : "https://snack.yummiespromociones.com/SnacksyummiesAssets/final_creators.webp";
  
  mediaItems.push({ 
    type: 'video', 
    url: v, 
    src: undefined, 
    youtubeId: ytId, 
    thumb 
  });
}
---

<div style="background-image: url('https://snack.yummiespromociones.com/SnacksyummiesAssets/bgcontactzibas.webp'); background-size: cover; background-position: center; background-repeat: no-repeat;" class="pb-0 overflow-hidden">
  <div class="w-full max-w-6xl mx-auto px-4 py-16">
    {isLoading ? (
      <BlogDetailSkeleton />
    ) : (
      <>
        <Breadcrumb bgColor="bg-transparent" textColor="text-white" hoverColor="hover:text-white" />

        <!-- Title -->
        <div class="w-full mx-auto my-6">
          <div class="mb-8">
            <h1 class="font-title text-3xl md:text-6xl font-bold text-white mb-4 italic text-center" transition:name={`blog-title-${blogPost.id}`}>
              {blogPost.title}
            </h1>
          </div>
        </div>

        <!-- Media Carousel -->
        {mediaItems.length > 0 && (
          <div class="max-w-6xl mx-auto mb-8">
            <MediaCarousel 
              items={mediaItems} 
              aspectRatio="16/9"
            />
          </div>
        )}

        <!-- Content -->
        <div class="blog-content prose prose-lg max-w-none my-8 text-md md:text-lg text-white" transition:animate={fade({ duration: '0.5s' })}>
          <Fragment set:html={blogPost.content} />
        </div>

        <!-- Share -->
        <div class="w-full flex justify-end mb-8">
          <button type="button"
            class="flex items-center gap-2 px-4 py-2 font-bold text-white border-2 border-white bg-orange rounded-md hover:brightness-110 transition"
            onclick="window.showShareModal && window.showShareModal('shareModal-blog')"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="25" viewBox="0 0 24 25" fill="none">
              <path d="M9.39713 5.30615H8.35547C5.40919 5.30615 3.93605 5.30615 3.02076 6.18483C2.10547 7.06351 2.10547 8.47772 2.10547 11.3062V15.3062C2.10547 18.1346 2.10547 19.5488 3.02076 20.4275C3.93605 21.3062 5.40919 21.3062 8.35547 21.3062H12.5621C15.5084 21.3062 16.9815 21.3062 17.8968 20.4275C18.4898 19.8582 18.6986 19.0641 18.7721 17.8062" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M16.1667 7.80615V4.6597C16.1667 4.46444 16.3316 4.30615 16.535 4.30615C16.6326 4.30615 16.7263 4.3434 16.7954 4.4097L21.5275 8.9526C21.7634 9.17897 21.8958 9.48601 21.8958 9.80615C21.8958 10.1263 21.7634 10.4333 21.5275 10.6597L16.7954 15.2026C16.7263 15.269 16.6326 15.3062 16.535 15.3062C16.3316 15.3062 16.1667 15.1479 16.1667 14.9526V11.8062H13.1157C8.875 11.8062 7.3125 15.3062 7.3125 15.3062V12.8062C7.3125 10.0447 9.64435 7.80615 12.5208 7.80615H16.1667Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            {currentLang === 'es' ? 'Compartir' : 'Share'}
          </button>
        </div>

        {suggestedPosts.length > 0 && (
          <section class="mt-16 mb-0 pb-8" transition:animate={fade({ duration: '0.7s' })}>
            <h2 class="text-white font-title text-4xl md:text-6xl font-bold text-left mb-8">{readMoreTitle}</h2>
            <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-8 mx-auto max-w-7xl">
              {suggestedPosts.map((post) => (
                <BlogCard 
                  preview={post.preview}
                  image={post.image}
                  title={post.title}
                  id={post.id}
                  slug={post.slug || post.id}
                  published_date={post.published_date}
                />
              ))}
            </div>
          </section>
        )}
      </>
    )}
  </div>
</div>

<VideoModal />

<!-- Share Modal -->
<ShareModal
  id="shareModal-blog"
  url={Astro.url.href}
  title={blogPost.title}
  description={''}
  hashtags={[]}
  showLabels={false}
  iconSize={40}
  round={true}
  openTextEs="Comparte esta noticia en tus redes sociales"
  openTextEn="Share this news on your social networks"
  acceptTextEs="Aceptar"
  acceptTextEn="Accept"
/>

<style>
  .animate-zoom {
    animation: zoom 15s linear infinite;
  }
  @keyframes zoom {
    0% { transform: scale(1); }
    50% { transform: scale(1.1); }
    100% { transform: scale(1); }
  }
</style>